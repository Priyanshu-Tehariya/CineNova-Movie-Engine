# --- TELEGRAM BOT CREDENTIALS ---
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=TheCineNovaBot

# --- ACCESS & CHANNEL ROUTING ---
ADMIN_IDS=[1234567890]
STORAGE_CHANNEL_ID=-100xxxxxxxxxx
LOG_CHANNEL_ID=-100xxxxxxxxxx
REQUEST_CHANNEL_ID=-100xxxxxxxxxx

# --- FORCE JOIN CONFIGURATION ---
FORCE_JOIN_CHANNELS=-100xxxxxxxxxx
FORCE_JOIN_CACHE_TTL=3600

# --- DATABASE PIPELINE (POSTGRESQL) ---
DATABASE_URL=postgresql+asyncpg://botuser:your_password_here@postgres:5432/moviebot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- CACHE PIPELINE (REDIS) ---
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# --- AUTOMATION & CLEANUP TIMEOUTS ---
AUTO_DELETE_TIMEOUT=120
AUTO_DELETE_WARNING_TIME=15

# --- ANTI-FLOOD & SEARCH CONFIGURATION ---
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_WINDOW=10
SEARCH_CACHE_TTL=300
MAX_SEARCH_RESULTS=8

# --- SYSTEM LOGGING ---
LOG_LEVEL=INFO
LOG_JSON=false